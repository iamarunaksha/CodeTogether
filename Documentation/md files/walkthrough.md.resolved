### 11 — Rewrite `App.jsx` (The Conductor)

This is the big one. `App.jsx` becomes the **layout orchestrator** — it arranges all components, manages state, and handles Socket.IO sync.

Replace the entire contents of `Frontend/src/App.jsx`:

```jsx
import { useState, useEffect, useRef, useCallback } from 'react';
import { io } from 'socket.io-client';

// VS Code Shell Components
import TitleBar from './Components/TitleBar';
import ActivityBar from './Components/ActivityBar';
import Sidebar from './Components/Sidebar';
import TabBar from './Components/TabBar';
import WelcomeTab from './Components/WelcomeTab';
import StatusBar from './Components/StatusBar';
import CodeEditor from './Components/CodeEditor';

// Counter for generating unique tab IDs
let tabIdCounter = 0;
const createTabId = () => `tab-${++tabIdCounter}`;

function App() {
  // ---- Connection State (from Phase 2) ----
  const [backendStatus, setBackendStatus] = useState('checking');
  const [socketStatus, setSocketStatus] = useState('disconnected');

  // ---- Editor State (from Phase 3) ----
  const [code, setCode] = useState('// Welcome to CodeTogether!\n// Start typing...\n\nfunction hello() {\n  console.log("Hello, world!");\n}\n');
  const [language, setLanguage] = useState('javascript');
  const [cursorPosition, setCursorPosition] = useState({ line: 1, column: 1 });

  // ---- NEW: UI Layout State (Phase 3.5) ----
  const [activePanel, setActivePanel] = useState('explorer');  // Which sidebar panel
  const [tabs, setTabs] = useState([
    { id: 'welcome', name: 'Welcome', type: 'welcome' },      // Start with Welcome tab
  ]);
  const [activeTab, setActiveTab] = useState('welcome');

  // ---- Refs ----
  const socketRef = useRef(null);
  const isRemoteChange = useRef(false);

  // ---- Socket.IO Connection (same as Phase 2) ----
  useEffect(() => {
    fetch('/api/health')
      .then((res) => res.json())
      .then(() => setBackendStatus('connected'))
      .catch(() => setBackendStatus('disconnected'));

    const socket = io('http://localhost:3001');
    socketRef.current = socket;

    socket.on('connect', () => {
      console.log('🔌 WebSocket connected:', socket.id);
      setSocketStatus('connected');
    });

    socket.on('code-change', (data) => {
      isRemoteChange.current = true;
      setCode(data.content);
    });

    socket.on('disconnect', () => setSocketStatus('disconnected'));

    return () => socket.disconnect();
  }, []);

  // ---- Editor Change Handler (same as Phase 3) ----
  const handleCodeChange = useCallback((newCode) => {
    setCode(newCode);
    if (!isRemoteChange.current) {
      socketRef.current?.emit('code-change', { content: newCode });
    }
    isRemoteChange.current = false;
  }, []);

  // ---- NEW: Tab Management Functions ----
  
  // Open a file from the Explorer → creates a new tab
  const openFile = useCallback((fileName) => {
    // Don't open duplicate tabs
    const existingTab = tabs.find((t) => t.name === fileName);
    if (existingTab) {
      setActiveTab(existingTab.id);
      return;
    }

    // Detect language from file extension
    const ext = fileName.split('.').pop().toLowerCase();
    const langMap = {
      js: 'javascript', jsx: 'javascript', ts: 'typescript',
      json: 'json', md: 'markdown', css: 'css', html: 'html',
    };

    const newTab = {
      id: createTabId(),
      name: fileName,
      type: 'editor',
      language: langMap[ext] || 'plaintext',
    };

    setTabs((prev) => [...prev, newTab]);
    setActiveTab(newTab.id);
    setLanguage(newTab.language);
  }, [tabs]);

  // Create a new empty file
  const handleNewFile = useCallback(() => {
    const newTab = { id: createTabId(), name: 'Untitled-1', type: 'editor', language: 'plaintext' };
    setTabs((prev) => [...prev, newTab]);
    setActiveTab(newTab.id);
    setCode('');
    setLanguage('plaintext');
  }, []);

  // Close a tab
  const closeTab = useCallback((tabId) => {
    setTabs((prev) => {
      const newTabs = prev.filter((t) => t.id !== tabId);
      if (activeTab === tabId && newTabs.length > 0) {
        setActiveTab(newTabs[newTabs.length - 1].id);
      } else if (newTabs.length === 0) {
        setActiveTab('welcome');
        return [{ id: 'welcome', name: 'Welcome', type: 'welcome' }];
      }
      return newTabs;
    });
  }, [activeTab]);

  // Switch between tabs
  const switchTab = useCallback((tabId) => {
    setActiveTab(tabId);
    const tab = tabs.find((t) => t.id === tabId);
    if (tab?.language) setLanguage(tab.language);
  }, [tabs]);

  // Track cursor position from Monaco
  const handleEditorMount = useCallback((editor) => {
    editor.onDidChangeCursorPosition((e) => {
      setCursorPosition({ line: e.position.lineNumber, column: e.position.column });
    });
  }, []);

  // Which tab is currently showing?
  const currentTab = tabs.find((t) => t.id === activeTab);

  // ---- The VS Code Layout ----
  return (
    <div className="vscode-app">
      {/* Zone 1: Title Bar */}
      <TitleBar socketStatus={socketStatus} backendStatus={backendStatus} />

      {/* Zones 2-5: Main content area */}
      <div className="vscode-main">
        {/* Zone 2: Activity Bar */}
        <ActivityBar activePanel={activePanel} onPanelChange={setActivePanel} />

        {/* Zone 4: Sidebar (conditionally rendered) */}
        <Sidebar activePanel={activePanel} onFileOpen={openFile} />

        {/* Zones 3+5: Tab Bar + Editor */}
        <div className="vscode-editor-area">
          <TabBar tabs={tabs} activeTab={activeTab} onTabClick={switchTab} onTabClose={closeTab} />
          <div className="vscode-editor-content">
            {currentTab?.type === 'welcome' ? (
              <WelcomeTab onNewFile={handleNewFile} />
            ) : (
              <CodeEditor value={code} onChange={handleCodeChange} language={language} onMount={handleEditorMount} />
            )}
          </div>
        </div>
      </div>

      {/* Zone 6: Status Bar */}
      <StatusBar language={language} socketStatus={socketStatus}
        lineNumber={cursorPosition.line} columnNumber={cursorPosition.column} />
    </div>
  );
}

export default App;
```

> **Key concept — `useCallback`**
>
> You'll notice we wrap many functions in `useCallback`. Here's why:
>
> | Without useCallback | With useCallback |
> |---|---|
> | Every time App re-renders, a NEW function object is created | The SAME function object is reused across re-renders |
> | Child components receive a "new" prop and re-render unnecessarily | Child components see the same prop and skip re-rendering |
>
> It's a **performance optimization**. In a complex app with many components, unnecessary re-renders slow things down. `useCallback` says: "only create a new version of this function when its dependencies change."

---

### 12 — Update `CodeEditor.jsx`

One small update needed — we add an `onMount` prop so App.jsx can track cursor position:

Update `Frontend/src/Components/CodeEditor.jsx`:

```jsx
import Editor from '@monaco-editor/react';

function CodeEditor({ value, onChange, language = 'javascript', onMount }) {
  const handleEditorChange = (newValue) => {
    if (onChange) onChange(newValue);
  };

  const handleEditorMount = (editor, monaco) => {
    if (onMount) onMount(editor, monaco);  // Pass editor instance to App.jsx
    editor.focus();                         // Auto-focus the editor
  };

  return (
    <Editor
      height="100%"
      language={language}
      value={value}
      theme="vs-dark"
      onChange={handleEditorChange}
      onMount={handleEditorMount}
      options={{
        fontSize: 14,
        fontFamily: "'Fira Code', 'Cascadia Code', 'Consolas', monospace",
        fontLigatures: true,
        minimap: { enabled: true },
        scrollBeyondLastLine: false,
        wordWrap: 'on',
        automaticLayout: true,
        tabSize: 2,
        lineNumbers: 'on',
        renderLineHighlight: 'line',
        cursorBlinking: 'smooth',
        cursorSmoothCaretAnimation: 'on',
        smoothScrolling: true,
        bracketPairColorization: { enabled: true },
        padding: { top: 16 },
      }}
    />
  );
}

export default CodeEditor;
```

> **What's new**: The `onMount` callback fires once when Monaco finishes loading. We use it to attach a cursor position listener that updates the Status Bar's "Ln X, Col Y" display in real-time as you move your cursor.

