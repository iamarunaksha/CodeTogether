### Step 4: Update `RoomPage.jsx` — The Orchestrator

This is the big integration step. We need to:
1. Import the new components and `executeCode`
2. Add state for terminal output and visibility
3. Create `handleRun` and `handleClear` functions
4. Wire the "▶ Run" button (in the tab bar area) and the terminal panel
5. Add a keyboard shortcut (`Ctrl+Enter`) for running code

Open `Frontend/src/pages/RoomPage.jsx` and make these changes:

**At the top — add imports:**
```javascript
import TerminalPanel from '../Components/TerminalPanel';
import { executeCode } from '../lib/codeRunner';
import { VscPlay } from 'react-icons/vsc';
```

**Add state for the terminal (after the presence state):**
```javascript
// ---- Terminal State (Phase 8) ----
const [terminalOutput, setTerminalOutput] = useState([]);
const [terminalOpen, setTerminalOpen] = useState(false);
const [isRunning, setIsRunning] = useState(false);

// Store the Monaco editor instance so we can read its value
const editorRef = useRef(null);
```

**Update `handleEditorMount` to store the editor ref and add Ctrl+Enter shortcut:**
```javascript
const handleEditorMount = useCallback((editor, monaco) => {
  editorRef.current = editor;  // Store editor for code reading
  editor.onDidChangeCursorPosition((e) => {
    setCursorPosition({
      line: e.position.lineNumber,
      column: e.position.column,
    });
  });

  // Ctrl+Enter / Cmd+Enter keyboard shortcut to run code
  editor.addAction({
    id: 'run-code',
    label: 'Run Code',
    keybindings: [
      monaco.KeyMod.CtrlCmd | monaco.KeyCode.Enter,
    ],
    run: () => handleRun(),
  });
}, []);
```

**Add the `handleRun` and `handleClear` functions (after cursor tracking):**
```javascript
// ---- Code Execution (Phase 8) ----
const handleRun = useCallback(() => {
  if (isRunning) return;

  const code = editorRef.current?.getValue() || '';
  if (!code.trim()) {
    setTerminalOutput(prev => [...prev, {
      type: 'system', args: ['No code to execute.'],
    }]);
    setTerminalOpen(true);
    return;
  }

  setIsRunning(true);
  setTerminalOpen(true);

  setTerminalOutput(prev => [...prev, {
    type: 'system',
    args: ['▶ Running JavaScript... (' + new Date().toLocaleTimeString() + ')'],
  }]);

  executeCode(
    code,
    (output) => setTerminalOutput(prev => [...prev, output]),
    () => {
      setTerminalOutput(prev => [...prev, {
        type: 'system', args: ['✓ Program exited.'],
      }]);
      setIsRunning(false);
    },
    5000
  );
}, [isRunning]);

const handleClear = useCallback(() => {
  setTerminalOutput([]);
}, []);
```

**Update the JSX — wrap TabBar with Run button, add TerminalPanel below editor:**
```jsx
<div className="vscode-editor-area">
  <div style={{ display: 'flex', alignItems: 'center' }}>
    <TabBar
      tabs={tabs}
      activeTab={activeTab}
      onTabClick={switchTab}
      onTabClose={closeTab}
    />
    <button
      className="vscode-run-button"
      onClick={handleRun}
      disabled={isRunning}
      title="Run Code (Ctrl+Enter)"
    >
      <VscPlay style={{ fontSize: 14 }} />
      {isRunning ? 'Running...' : 'Run'}
    </button>
  </div>

  <div className="vscode-editor-content">
    {currentTab?.type === 'editor' ? (
      <CodeEditor
        language={language}
        onMount={handleEditorMount}
        yText={yText}
        provider={provider}
      />
    ) : null}
  </div>

  {terminalOpen && (
    <TerminalPanel
      output={terminalOutput}
      onRun={handleRun}
      onClear={handleClear}
      onClose={() => setTerminalOpen(false)}
    />
  )}
</div>
```

